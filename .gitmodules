[submodule "dotbot"]
	path = dotbot
	url = https://github.com/anishathalye/dotbot
	ignore = dirty
[submodule "xmonad/xmonad"]
	path = xmonad/xmonad
	url = https://github.com/xmonad/xmonad
[submodule "xmonad/xmonad-contrib"]
	path = xmonad/xmonad-contrib
	url = https://github.com/xmonad/xmonad-contrib
[submodule "xmonad/xmonad-dbus"]
	path = xmonad/xmonad-dbus
	url = https://github.com/troydm/xmonad-dbus
[submodule "rofi/themes/gruvbox"]
	path = rofi/themes/gruvbox
	url = https://github.com/bardisty/gruvbox-rofi.git
[submodule "kitty/kitty-themes"]
	path = kitty/kitty-themes
	url = https://github.com/dexpota/kitty-themes.git
